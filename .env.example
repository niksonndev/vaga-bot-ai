OPENAI_API_KEY=coloque_sua_chave_aqui
DEFAULT_SEARCH_LIMIT=20
MAX_SEARCH_RESULTS=1000

# LinkedIn (opcional — se preenchido, faz login para obter mais resultados)
LINKEDIN_EMAIL=
LINKEDIN_PASSWORD=

# Indeed: login é feito manualmente via navegador visível (headed mode).
# Na primeira execução (ou quando cookies expirarem), o app abre o navegador
# para você fazer login no Indeed (Google, Apple ou código por email).
# Os cookies são salvos em data/indeed-cookies.json e reutilizados.

# CapSolver (opcional — para bypass automático de CAPTCHA no login do LinkedIn)
# Crie uma conta em https://dashboard.capsolver.com/ e copie sua API key
CAPSOLVER_API_KEY=
